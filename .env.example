# ─────────────────────────────────────────────────────────────────────────────
# Attestara — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Tenderly ──────────────────────────────────────────────────────────────────
TENDERLY_API_KEY=Tqmx5UBedpKgo1HVIj48TWaV8AZLOPQX
TENDERLY_ACCOUNT_SLUG=subhankar
TENDERLY_PROJECT_SLUG=project

# Populated automatically by `npm run fork:setup`
TENDERLY_FORK_RPC=
TENDERLY_FORK_ID=
TENDERLY_PUBLIC_RPC=

# ── Deployer wallet (used to deploy contracts to Tenderly fork) ───────────────
# Generate with: node -e "const {ethers}=require('ethers');const w=ethers.Wallet.createRandom();console.log(w.privateKey,w.address)"
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=

# ── CRE Signer (generated automatically on first CRE start if not set) ────────
# After first CRE start, copy the printed address here and redeploy contracts
CRE_SIGNER_PRIVATE_KEY=
CRE_SIGNER_ADDRESS=

# ── Network ───────────────────────────────────────────────────────────────────
CHAIN_ID=1
RPC_URL=

# ── Contract Addresses (populated automatically by `npm run deploy`) ──────────
DID_REGISTRY_ADDRESS=
VERIFIER_ADDRESS=
VAULT_ADDRESS=

# ── External Contract Addresses (mainnet, populated by fork:setup) ────────────
USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48
AAVE_ARC_LENDING_POOL=0x37D7306019a38Af123e4b245Eb6C28AF552e0bB0
AAVE_ARC_PERMISSION_MANAGER=0xF4a1F5fEA79C3609514A417425971FadC10eCfBE

# ── AML Provider ─────────────────────────────────────────────────────────────
# Leave blank to use mock AML server (default)
# Set to your Chainalysis API key to use the real adapter
CHAINALYSIS_API_KEY=

# ── Service Ports ─────────────────────────────────────────────────────────────
CRE_PORT=4000
MOCK_AML_PORT=4001
FRONTEND_PORT=3000

# ── Mock AML URL (used by CRE to reach the mock server) ──────────────────────
MOCK_AML_URL=http://localhost:4001

# ── Infura (optional — only needed for local hardhat forking, not Tenderly) ───
INFURA_KEY=
